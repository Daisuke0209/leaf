# Google OAuth client ID (Google Cloud Console > Credentials > OAuth client ID,
# type "Web application"). Client-only GIS flow: no secret needed, but the
# app's origin must be listed under "Authorized JavaScript origins".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# URL of the deployed auth worker (worker/), which verifies Drive access and
# issues Liveblocks room tokens. Optional: enables real-time collaborative
# editing. Leave empty for solo mode.
NEXT_PUBLIC_LIVEBLOCKS_AUTH_URL=
